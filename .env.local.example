AI_ASSISTANT_OPENAI_ENABLED=true
AI_ASSISTANT_OPENAI_BASE_URL=https://v2.aicodee.com
AI_ASSISTANT_OPENAI_API_KEY=replace-with-your-api-key
AI_ASSISTANT_CHAT_PROVIDER=openai
AI_ASSISTANT_CHAT_MODEL=MiniMax-M2.7-highspeed
AI_ASSISTANT_CHAT_TEMPERATURE=0.7

AI_ASSISTANT_EMBEDDING_PROVIDER=openai
AI_ASSISTANT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
AI_ASSISTANT_EMBEDDING_BASE_URL=http://127.0.0.1:18080
AI_ASSISTANT_EMBEDDING_API_KEY=tei
AI_ASSISTANT_EMBEDDING_DIMENSIONS=512
AI_ASSISTANT_EMBEDDING_PATH=/v1/embeddings

AI_ASSISTANT_RERANK_ENABLED=false
AI_ASSISTANT_RERANK_PROVIDER=local
AI_ASSISTANT_RERANK_MODEL=BAAI/bge-reranker-base
AI_ASSISTANT_RERANK_BASE_URL=http://127.0.0.1:17997
AI_ASSISTANT_RERANK_API_KEY=local-rerank
AI_ASSISTANT_RERANK_PATH=/rerank

AI_ASSISTANT_DB_HOST=127.0.0.1
AI_ASSISTANT_DB_PORT=3306
AI_ASSISTANT_DB_NAME=ai_assistant
AI_ASSISTANT_DB_USERNAME=root
AI_ASSISTANT_DB_PASSWORD=replace-with-your-db-password
AI_ASSISTANT_DB_USE_SSL=false
AI_ASSISTANT_DB_TIMEZONE=GMT%2B8

AI_ASSISTANT_REDIS_HOST=127.0.0.1
AI_ASSISTANT_REDIS_PORT=6379
AI_ASSISTANT_REDIS_PASSWORD=replace-with-your-redis-password

AI_ASSISTANT_QDRANT_HOST=127.0.0.1
AI_ASSISTANT_QDRANT_PORT=6334

AI_ASSISTANT_UPLOAD_DIR=/Users/rengang/chuangye/osh-projects/osh-rag/osh-qa-assistant/文档/upload
