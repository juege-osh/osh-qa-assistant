<?xml version="1.0" encoding="UTF-8"?>

<configuration scan="false">
  <appender name="stdout" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} %line: %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!--mapper包打印执行的sql,需要日志级别为debug-->
  <logger name="com.osh.ai.assistant.consumer.mapper" level="debug" additivity="false">
    <appender-ref ref="stdout"/>
  </logger>
  <!--打印日志advisor记录的信息-->
  <logger name="org.springframework.ai.chat.client.advisor.SimpleLoggerAdvisor" level="debug" additivity="false">
    <appender-ref ref="stdout"/>
  </logger>
  <root level="info">
    <appender-ref ref="stdout"/>
  </root>

</configuration>
