# Copy this file to .qaenv-laughing.env.local and fill in real values.
# This file is only for the manual deploy script:
#   QAENV_DEPLOY_PASSWORD='...' ./scripts/qaenv-laughing-deploy.sh

AI_ASSISTANT_DB_HOST=43.242.200.25
AI_ASSISTANT_DB_PORT=53306
AI_ASSISTANT_DB_NAME=ai_assistant
AI_ASSISTANT_DB_USERNAME=root
AI_ASSISTANT_DB_PASSWORD=replace-me
AI_ASSISTANT_DB_USE_SSL=false
AI_ASSISTANT_DB_TIMEZONE=GMT%2B8

AI_ASSISTANT_REDIS_HOST=43.242.200.25
AI_ASSISTANT_REDIS_PORT=56379
AI_ASSISTANT_REDIS_PASSWORD=replace-me

AI_ASSISTANT_QDRANT_HOST=43.242.200.25
AI_ASSISTANT_QDRANT_PORT=56334
SPRING_AI_VECTORSTORE_QDRANT_INITIALIZE_SCHEMA=false

AI_ASSISTANT_OPENAI_ENABLED=true
AI_ASSISTANT_OPENAI_BASE_URL=https://example.invalid
AI_ASSISTANT_OPENAI_API_KEY=replace-me
AI_ASSISTANT_CHAT_PROVIDER=openai
AI_ASSISTANT_CHAT_MODEL=replace-me
AI_ASSISTANT_CHAT_TEMPERATURE=0.7

AI_ASSISTANT_EMBEDDING_PROVIDER=openai
AI_ASSISTANT_EMBEDDING_MODEL=replace-me
AI_ASSISTANT_EMBEDDING_BASE_URL=https://example.invalid
AI_ASSISTANT_EMBEDDING_API_KEY=replace-me
AI_ASSISTANT_EMBEDDING_DIMENSIONS=512
AI_ASSISTANT_EMBEDDING_PATH=/v1/embeddings

AI_ASSISTANT_RERANK_ENABLED=false
AI_ASSISTANT_RERANK_PROVIDER=local
AI_ASSISTANT_RERANK_MODEL=BAAI/bge-reranker-base
AI_ASSISTANT_RERANK_BASE_URL=http://127.0.0.1:17997
AI_ASSISTANT_RERANK_API_KEY=local-rerank
AI_ASSISTANT_RERANK_PATH=/rerank

AI_ASSISTANT_ALERT_ENABLED=false
AI_ASSISTANT_ALERT_SUBJECT_PREFIX=[OSH QA Assistant]
AI_ASSISTANT_ALERT_FROM=
AI_ASSISTANT_ALERT_RECIPIENTS=
AI_ASSISTANT_ALERT_DEDUPE_MINUTES=30
AI_ASSISTANT_ALERT_RECOVERY_ENABLED=true
AI_ASSISTANT_ALERT_SELF_CHECK_ENABLED=false
AI_ASSISTANT_ALERT_SELF_CHECK_ALLOWED_USERS=laughing
AI_ASSISTANT_ALERT_SMTP_HOST=
AI_ASSISTANT_ALERT_SMTP_PORT=587
AI_ASSISTANT_ALERT_SMTP_USERNAME=
AI_ASSISTANT_ALERT_SMTP_PASSWORD=replace-me
AI_ASSISTANT_ALERT_SMTP_PROTOCOL=smtp
AI_ASSISTANT_ALERT_SMTP_AUTH=true
AI_ASSISTANT_ALERT_SMTP_SSL_ENABLE=false
AI_ASSISTANT_ALERT_SMTP_SSL_TRUST=
AI_ASSISTANT_ALERT_SMTP_STARTTLS=true
AI_ASSISTANT_DB_PROBE_ENABLED=true
AI_ASSISTANT_DB_PROBE_WARN_AFTER_SECONDS=10
AI_ASSISTANT_DB_PROBE_RETRY_INTERVAL_SECONDS=10
AI_ASSISTANT_DB_PROBE_CHECK_TIMEOUT_SECONDS=5
AI_ASSISTANT_QDRANT_PROBE_ENABLED=true
AI_ASSISTANT_QDRANT_PROBE_WARN_AFTER_SECONDS=10
AI_ASSISTANT_QDRANT_PROBE_CHECK_TIMEOUT_SECONDS=10
AI_ASSISTANT_QDRANT_PROBE_RETRY_INTERVAL_SECONDS=10

AI_ASSISTANT_UPLOAD_STORAGE_TYPE=oss
AI_ASSISTANT_OSS_ACCESS_KEY=replace-me
AI_ASSISTANT_OSS_SECRET_KEY=replace-me
AI_ASSISTANT_OSS_ENDPOINT=https://example.invalid
AI_ASSISTANT_OSS_BUCKET_NAME=replace-me
AI_ASSISTANT_OSS_PUBLIC_DOMAIN=https://example.invalid
AI_ASSISTANT_OSS_BASE_PATH=resources/
AI_ASSISTANT_OSS_PATH_STYLE_ACCESS=true

LAUGHING_HTTP_PORT=18088
LAUGHING_BACKEND_PORT=19088
LAUGHING_BACKEND_MEMORY_LIMIT=768m
LAUGHING_JAVA_INITIAL_RAM_PERCENTAGE=20
LAUGHING_JAVA_MAX_RAM_PERCENTAGE=50
